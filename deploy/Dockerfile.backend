FROM python:3.12-slim

WORKDIR /app
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
ENV CONTRACTS_DIR=/app/contracts
ENV DATABASE_PATH=/tmp/guardian.db
ENV USE_AGENT_BUILDER=true
ENV GEMINI_BACKEND=auto
ENV GEMINI_MODEL=gemini-3.5-flash
ENV GEMINI_FALLBACK_MODEL=gemini-2.5-flash
ENV GEMINI_LOCATION=us-central1
ENV FIVETRAN_MCP_COMMAND=fivetran-mcp
ENV FIVETRAN_MCP_ARGS=
ENV PIP_DEFAULT_TIMEOUT=120

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl git \
    && rm -rf /var/lib/apt/lists/*

COPY backend/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt \
    && pip install --no-cache-dir "git+https://github.com/fivetran/fivetran-mcp"

COPY backend/app /app/app
COPY backend/agent_builder /app/agent_builder
COPY contracts /app/contracts

RUN chown -R nobody:nogroup /app 2>/dev/null || chown -R nobody:nobody /app
USER nobody

EXPOSE 8080
CMD ["sh", "-c", "exec uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8080}"]
