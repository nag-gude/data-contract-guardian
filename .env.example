# Copy to backend/.env and frontend/.env.local as needed

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gemini — Google Cloud AI (Vertex on GCP; AI Studio for local), via the google-genai SDK
GEMINI_API_KEY=
# ADK + Vertex (maps GCP_PROJECT_ID → GOOGLE_CLOUD_PROJECT at runtime)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_BACKEND=auto
# Safety guardrails: BLOCK_NONE | BLOCK_ONLY_HIGH | BLOCK_MEDIUM_AND_ABOVE | BLOCK_LOW_AND_ABOVE
GEMINI_SAFETY_THRESHOLD=BLOCK_ONLY_HIGH
GCP_PROJECT_ID=
# Fivetran destination dataset when contract YAML uses placeholder network
BQ_DATASET=
GCP_LOCATION=us-central1
# Vertex region for Gemini (align with Cloud Run — gemini-3.5-flash on us-central1)
GEMINI_LOCATION=us-central1

# Google Cloud Agent Builder / ADK + MCPToolset
USE_AGENT_BUILDER=true
REQUIRE_AGENT_BUILDER=false
AGENT_NAME=data_contract_guardian

SLACK_WEBHOOK_URL=

# Fivetran MCP — stdio transport (github.com/fivetran/fivetran-mcp)
# See docs/FIVETRAN.md for ingestion setup (connectors → BigQuery) before going live.
MOCK_FIVETRAN_MCP=true
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
# Optional: Fivetran dashboard slug (e.g. toll_donator) OR schema/name hint (e.g. hackathon).
# Hints are resolved via list_connections — never used as the raw API connection id.
# Same value as terraform.tfvars → fivetran_connection_id. Leave empty to auto-resolve.
FIVETRAN_CONNECTION_ID=
FIVETRAN_ALLOW_WRITES=false
FIVETRAN_MCP_COMMAND=uvx
FIVETRAN_MCP_ARGS=--from,git+https://github.com/fivetran/fivetran-mcp,fivetran-mcp

MOCK_BIGQUERY=true
# Set false after Fivetran syncs into BigQuery — see docs/FIVETRAN.md Step 4

BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
